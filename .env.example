# Chave da OpenAI. Nunca coloque essa chave no navegador.
OPENAI_API_KEY=

# Modelo usado pela atendente. Pode trocar depois conforme custo/qualidade.
OPENAI_MODEL=gpt-5.4-mini

# Servidor local
APP_HOST=0.0.0.0
APP_PORT=6060

# Pastas e banco local
DATA_DIR=data
MEDIA_DIR=midia
CATALOG_DIR=catalogos
DATABASE_PATH=atendente.db
